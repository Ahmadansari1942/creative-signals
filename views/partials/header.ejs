<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Creative Signals - Personal blog and portfolio at the intersection of technology and art">
  <title><%= title %></title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Styles -->
  <link rel="stylesheet" href="/css/style.css">
  
  <!-- Open Graph -->
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="Creative Signals - Technology meets art">
  <meta property="og:type" content="website">
</head>
<body>
  <!-- Noise Overlay -->
  <div class="noise-overlay"></div>
  
  <!-- Navigation -->
  <nav class="nav" id="mainNav">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <span class="logo-text">Creative Signals</span>
        <span class="logo-dot"></span>
      </a>
      
      <div class="nav-links">
        <a href="/" class="nav-link <%= currentPage === 'home' ? 'active' : '' %>">Home</a>
        <a href="/blog" class="nav-link <%= currentPage === 'blog' ? 'active' : '' %>">Writings</a>
        <a href="/experiments" class="nav-link <%= currentPage === 'experiments' ? 'active' : '' %>">Experiments</a>
        <a href="/timeline" class="nav-link <%= currentPage === 'timeline' ? 'active' : '' %>">Journey</a>
        <a href="/contact" class="nav-link <%= currentPage === 'contact' ? 'active' : '' %>">Connect</a>
      </div>
      
      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
  
  <main class="main-content">
